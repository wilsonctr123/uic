#!/usr/bin/env bash
# uic-update-check — periodic version check
#
# Output (one line, or nothing):
#   JUST_UPGRADED <old> <new>     — upgrade just happened
#   UPGRADE_AVAILABLE <old> <new> — newer version exists on GitHub
#   (nothing)                     — up to date or check skipped
#
set -euo pipefail

UIC_DIR="${UIC_DIR:-$(cd "$(dirname "$0")/.." && pwd)}"
STATE_DIR="${UIC_STATE_DIR:-$HOME/.uic-state}"
CACHE_FILE="$STATE_DIR/last-update-check"
MARKER_FILE="$STATE_DIR/just-upgraded-from"
VERSION_FILE="$UIC_DIR/VERSION"
REMOTE_URL="${UIC_REMOTE_URL:-https://raw.githubusercontent.com/wilsonctr123/uic/main/VERSION}"

mkdir -p "$STATE_DIR"

# ── Check for just-upgraded marker ──
if [ -f "$MARKER_FILE" ]; then
  OLD_VER=$(cat "$MARKER_FILE")
  NEW_VER=$(cat "$VERSION_FILE" 2>/dev/null || echo "unknown")
  rm -f "$MARKER_FILE"
  echo "JUST_UPGRADED $OLD_VER $NEW_VER"
  exit 0
fi

# ── Rate limit: check at most once per hour ──
if [ -f "$CACHE_FILE" ]; then
  LAST_CHECK=$(cat "$CACHE_FILE")
  NOW=$(date +%s)
  ELAPSED=$(( NOW - LAST_CHECK ))
  if [ "$ELAPSED" -lt 3600 ]; then
    # Already checked recently — skip
    exit 0
  fi
fi

# ── Fetch remote version (timeout 3s, silent fail) ──
LOCAL_VER=$(cat "$VERSION_FILE" 2>/dev/null || echo "0.0.0")
REMOTE_VER=$(curl -sf --max-time 3 "$REMOTE_URL" 2>/dev/null | tr -d '[:space:]' || echo "")

# Record check time
date +%s > "$CACHE_FILE"

# ── Compare ──
if [ -z "$REMOTE_VER" ]; then
  # Couldn't reach GitHub — skip silently
  exit 0
fi

if [ "$LOCAL_VER" != "$REMOTE_VER" ]; then
  echo "UPGRADE_AVAILABLE $LOCAL_VER $REMOTE_VER"
fi
